# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://startpro:startpro@localhost:5432/startpro

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Must be at least 32 random characters in production
JWT_SECRET=change-this-to-a-random-32-char-string

# ─── App URL ──────────────────────────────────────────────────────────────────
# Used for invite links, password reset links, and CSRF validation
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Initial Super Admin Setup ────────────────────────────────────────────────
# Secret key required to call POST /api/auth/setup-admin
SETUP_SECRET=change-this-setup-secret

# ─── Email (optional — for password reset emails) ─────────────────────────────
# Without SMTP config, reset links are logged to console (development only)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@startpro.com.br
